# NetSentry Sensor — Environment Configuration
# Copy this file to .env and customize for your local edge hardware setup

# =============================================================================
# IMPORTANT: TOPOLOGY MIGRATION
# =============================================================================
# This configuration supports the NEW SPAN/Mirror Port topology.
# Before deploying, run: sudo ./scripts/setup/revert-bridge.sh revert
#
# Topology: [Modem] -> [Router] -> [Switch (SPAN)] -> [Pi IDPS]
# The Pi is now a PASSIVE sensor, not a gateway/bridge.
# =============================================================================

# =============================================================================
# AUTHENTICATION
# =============================================================================

# The unique API Key generated by the NetSentry Cloud Console for this sensor deployment
API_KEY=your-sensor-api-key-here

# =============================================================================
# WIREGUARD TUNNEL (Outbound Bridge Integration)
# =============================================================================

# The sensor's local WireGuard private key (generate on-device using: wg genkey)
WG_PRIVATE_KEY=

# The NetSentry Management VPS WireGuard public key
WG_VPS_PUBLIC_KEY=

# The public IP of your hosted NetSentry Cloud Management VPS
VPS_PUBLIC_IP=178.104.6.176

# Tunnel network assignments (must align with your central server schema)
WG_ADDRESS=10.10.0.2/24
WG_PORT=51820
WG_ALLOWED_IPS=10.10.0.1/32
WG_KEEPALIVE=25

# =============================================================================
# CONNECTIVITY — Edge Sensor ──► Management Cloud
# =============================================================================

# Base public API endpoint to communicate with the central orchestration server
VPS_API_URL=https://idps.brentweb.eu/api/vps

# Secure WebSocket endpoint routing metrics, health payloads, and active command events
VPS_WS_URL=wss://idps.brentweb.eu/ws/raspi

# Secure WebSocket stream channel dedicated exclusively to live packet delivery frames
PACKET_STREAM_WS_URL=wss://idps.brentweb.eu/ws/packets

# Internal service endpoints — all containers share the host network namespace
NETWORK_FILTER_URL=http://localhost:8092/api/v1
RULE_ENGINE_URL=http://localhost:8094/api/v1

# =============================================================================
# NETWORK INTERFACE & PACKET CAPTURE CONFIG
# =============================================================================

# WAN/Modem interface: Passive packet capturing and Suricata deep engine checks (no IP assigned)
# For SPAN topology: This should be the interface connected to switch Port 8 (mirror port)
CAPTURE_INTERFACE=eth0

# LAN/Router interface: Not used in SPAN topology (passive sensor only)
# RASPI_INTERFACE=eth1  # Deprecated - remove

# Mapping reference allowing the network-filter binary to bypass default container barriers
HOST_NETNS_PATH=/host_proc/1/ns/net

# =============================================================================
# FIREWALL ENFORCEMENT (SPAN Topology)
# =============================================================================

# Router/Firewall API URL for block/unblock commands
# This is the IP of your TP-Link Archer router
FIREWALL_API_URL=http://192.168.1.1

# Router API key (if required)
FIREWALL_API_KEY=

# NOTE: In SPAN topology, the Pi does NOT apply iptables rules directly.
# Instead, block requests are forwarded to the router's API.
# If the router doesn't support API-based blocking, the system operates
# in MONITORING-ONLY mode.

# =============================================================================
# ENGINE CONSTANTS (SURICATA)
# =============================================================================

# Mount path to the active engine live log output container destination
SURICATA_EVE_PATH=/var/log/suricata/eve.json

# Local rule path file populated dynamically via cloud engine distributions
SURICATA_CUSTOM_RULES=/etc/suricata/rules/idps-custom.rules

# =============================================================================
# DETECTION CONSTANTS & STREAMING RATES
# =============================================================================

# Token-bucket ceiling setting protecting the WebSocket channel against sudden volume bursts
MAX_PACKETS_PER_SECOND=10000
RATE_LIMITING_ENABLED=true

# =============================================================================
# HARDWARE DIAGNOSTICS & TELEMETRY
# =============================================================================

# Unique identifier representing this node inside your tracking infrastructure
DEVICE_ID=raspi-edge-01

# Collection interval pace tracking resource metrics (CPU, Ram, Temps)
COLLECTION_INTERVAL_SECS=10
TELEMETRY_PORT=8096

# =============================================================================
# SYSTEM LOG UTILITIES
# =============================================================================

# Rust environment trace control level (choices: error, warn, info, debug, trace)
RUST_LOG=info