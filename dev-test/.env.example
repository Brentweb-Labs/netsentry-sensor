# NetSentry Dev/Test Environment Variables
# Copy to .env and configure for your cloud connection

# =============================================================================
# MongoDB (local dev-test instance)
# =============================================================================
MONGO_ROOT_PASSWORD=DevPassword123!

# =============================================================================
# Redis (local dev-test instance)
# =============================================================================
REDIS_PASSWORD=DevRedis123!

# =============================================================================
# Cloud Connection (optional - for real cloud integration)
# =============================================================================
# VPS endpoint (when you want to connect to real cloud)
# Example: VPS_ENDPOINT=https://idps.brentweb.eu
VPS_ENDPOINT=http://localhost:8080

# WebSocket URL for cloud connection
VPS_WS_URL=ws://localhost:8080/ws

# API key for cloud authentication
API_KEY=dev-test-key-12345

# Device identifier for this sensor
DEVICE_ID=dev-test-sensor-01

# =============================================================================
# Network Configuration (matches docker-compose.yml)
# =============================================================================
# Internal network: 10.10.10.0/24
SURICATA_IP=10.10.10.3
VICTIM_IP=10.10.10.4
ATTACKER_IP=10.10.10.2
