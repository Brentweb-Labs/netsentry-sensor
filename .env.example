# NetSentry Sensor — Environment Configuration
# Copy this file to .env and fill in the values for your deployment.
#
# Default topology: SPAN / out-of-band (passive monitoring via switch port mirroring).
# For inline bridge mode, see docs/ARCHITECTURE.md and set SURICATA_IFACE=br0.

# =============================================================================
# AUTHENTICATION
# =============================================================================

# The unique API key issued by your NetSentry Cloud instance for this sensor.
# Generate one in the cloud console under Sensors → Add Sensor.
API_KEY=your-sensor-api-key-here

# =============================================================================
# WIREGUARD TUNNEL
# =============================================================================

# Generate a keypair on this machine:  wg genkey | tee wg.key | wg pubkey
# Paste the public key into your cloud console under Sensors → WireGuard Peers.
WG_PRIVATE_KEY=
WG_VPS_PUBLIC_KEY=

# Public IP of your NetSentry Cloud server (the WireGuard endpoint).
VPS_PUBLIC_IP=<your-cloud-server-public-ip>

# Tunnel addressing — must match the allocation in your cloud WireGuard config.
WG_ADDRESS=10.10.0.2/24
WG_PORT=51820
WG_ALLOWED_IPS=10.10.0.1/32
WG_KEEPALIVE=25

# =============================================================================
# CLOUD CONNECTIVITY
# =============================================================================

# Base REST API endpoint of your NetSentry Cloud instance.
# SaaS users: set to https://your-tenant.netsentry.io/api/vps
# Self-hosted: set to https://your-domain.example.com/api/vps
VPS_API_URL=https://your-netsentry-cloud.example.com/api/vps

# WebSocket endpoint — receives block/rule commands pushed from the cloud.
VPS_WS_URL=wss://your-netsentry-cloud.example.com/ws/raspi

# WebSocket endpoint — streams raw packet frames to the cloud analyzer.
PACKET_STREAM_WS_URL=wss://your-netsentry-cloud.example.com/ws/packets

# Internal service URLs (containers share the host network namespace).
NETWORK_FILTER_URL=http://localhost:8092/api/v1
RULE_ENGINE_URL=http://localhost:8094/api/v1

# =============================================================================
# NETWORK INTERFACE & PACKET CAPTURE
# =============================================================================

# Interface that Suricata and the packet-processor monitor for traffic.
# SPAN topology (default): the interface connected to the switch mirror port.
# Inline bridge topology: the WAN-side interface (eth0), or br0 for the bridge.
CAPTURE_INTERFACE=eth0
SURICATA_IFACE=eth0

# Network namespace path that lets the network-filter container escape to the
# host kernel's iptables.  Only needed in inline/bridge mode.
HOST_NETNS_PATH=/host_proc/1/ns/net

# =============================================================================
# FIREWALL ENFORCEMENT (SPAN topology — optional)
# =============================================================================

# If your network appliance (router, firewall) exposes a REST API for blocking,
# set this URL and the firewall-forwarder will relay block commands there.
# Leave empty for monitoring-only mode.
FIREWALL_API_URL=
FIREWALL_API_KEY=

# =============================================================================
# SURICATA ENGINE
# =============================================================================

SURICATA_EVE_PATH=/var/log/suricata/eve.json
SURICATA_CUSTOM_RULES=/etc/suricata/rules/idps-custom.rules

# =============================================================================
# DETECTION & RATE LIMITING
# =============================================================================

MAX_PACKETS_PER_SECOND=10000
RATE_LIMITING_ENABLED=true

# =============================================================================
# HARDWARE TELEMETRY
# =============================================================================

# Unique identifier for this sensor node shown in the cloud dashboard.
# Use a descriptive name: e.g. office-sensor-01, datacenter-edge-lon1
DEVICE_ID=sensor-node-01

COLLECTION_INTERVAL_SECS=10
TELEMETRY_PORT=8096

# =============================================================================
# DATABASE (edge-local, not exposed externally)
# =============================================================================

# Change these from the defaults before deploying to any shared network.
MONGO_ROOT_PASSWORD=change-me-before-deploy
REDIS_PASSWORD=change-me-before-deploy

# =============================================================================
# MONGO IMAGE (architecture override)
# =============================================================================

# ARM64 devices (Raspberry Pi 4, Cortex-A72) lack AVX and require mongo:4.4.18.
# x86_64 hosts can use a newer version.
# Default is the ARM64-safe version; override here if running on x86_64:
#   MONGO_IMAGE=mongo:7.0
MONGO_IMAGE=mongo:4.4.18

# =============================================================================
# LOGGING
# =============================================================================

RUST_LOG=info
