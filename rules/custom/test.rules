# Test rules for demonstration - more specific
alert http any any -> any any (msg:"HTTP Request Detected"; flow:established,to_server; http.method; content:"GET"; sid:1000001; rev:1;)
alert tcp any any -> any 22 (msg:"SSH Connection Attempt"; flow:established,to_server; flags:S; sid:1000002; rev:1;)
alert icmp any any -> any any (msg:"ICMP Ping Detected"; itype:8; sid:1000003; rev:1;)
alert dns any any -> any any (msg:"DNS Query Detected; dns.query; sid:1000004; rev:1;)
alert tls any any -> any any (msg:"TLS Handshake Detected"; tls.handshake.type:1; sid:1000005; rev:1;)
