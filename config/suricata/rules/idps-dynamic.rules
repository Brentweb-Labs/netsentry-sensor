# IDPS Dynamic Rules File
# Rules will be dynamically added here by the rule-engine service
# This file is initially empty and will be populated by the VPS

# Example rules (these will be replaced by dynamic rules)
# alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"Potential SQL Injection"; content:"SELECT"; nocase; sid:1000001; rev:1;)
# alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt"; flow:to_server,established; content:"SSH"; sid:1000002; rev:1;)
