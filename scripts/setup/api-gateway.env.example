# API Gateway Environment Configuration
# Copy to api-gateway.env in /opt/netsentry/

# Required: VPS endpoint for alert submission
VPS_ENDPOINT=https://idps.example.com

# WireGuard configuration
WG_ADDRESS=10.10.0.2/24
WG_PRIVATE_KEY=<your-wireguard-private-key>
WG_ENDPOINT=10.10.0.1:51820

# Optional: Health check interval
HEALTH_CHECK_INTERVAL=30
